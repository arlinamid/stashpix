<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4+ installer for the bundled stashpix app.

  Build (after PyInstaller produced dist/stashpix):
    wix build packaging/wix/Package.wxs ^
      -d StageDir=dist\\stashpix ^
      -d Version=1.5.0 ^
      -o packaging\out\stashpix-1.5.0.msi

  Keep UpgradeCode STABLE across releases so upgrades replace the old version.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <?define UpgradeCode = "3D8C1E9A-7B42-4F16-9C3E-1A2B3C4D5E6F" ?>

    <Package Name="stashpix"
             Manufacturer="Rózsavölgyi János"
           Version="$(var.Version)"
           UpgradeCode="$(var.UpgradeCode)"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of stashpix is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="StegoIcon" SourceFile="$(var.IconFile)" />
    <Property Id="ARPPRODUCTICON" Value="StegoIcon" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="stashpix" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="stashpix" />
    </StandardDirectory>

    <Feature Id="Main" Title="stashpix" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AppExtras" />
    </Feature>
  </Package>

  <!-- Harvest every file PyInstaller produced, preserving the folder structure. -->
  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.StageDir)\**" />
    </ComponentGroup>
  </Fragment>

  <!-- PATH entry (so `stego` works in any terminal) + GUI Start-menu shortcut. -->
  <Fragment>
    <ComponentGroup Id="AppExtras">
      <Component Id="PathEnv" Directory="INSTALLFOLDER"
                 Guid="A1B2C3D4-E5F6-4711-8899-0A1B2C3D4E5F">
        <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]"
                     Part="last" Action="set" System="yes" Permanent="no" />
        <RegistryValue Root="HKLM" Key="Software\stashpix" Name="PathAdded"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <Component Id="GuiShortcut" Directory="AppShortcutFolder"
                 Guid="B2C3D4E5-F6A7-4822-99AA-1B2C3D4E5F60">
        <Shortcut Id="GuiShortcutFile" Name="stashpix (GUI)"
                  Target="[INSTALLFOLDER]stashpix-gui.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="StegoIcon" />
        <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\stashpix" Name="ShortcutAdded"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
